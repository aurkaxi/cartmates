{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "architecture.md",
  ],
  "lsp": true,
  "permission": {
    "bash": "allow",
    "edit": "ask",
    "git_status": "allow",
    "git_diff": "allow",
    "git_log": "allow",
    "git_show": "allow",
    "git_*": "ask",
    "flutter_doctor": "allow",
    "flutter_pub_get": "allow",
    "flutter_test": "allow",
    "flutter_analyze": "allow",
    "flutter_*": "ask"
  },
  "mcp": {
    "dart-mcp-server": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "formatter": {
    "dart": {
      "command": [
        "dart",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".dart"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "build/**",
      ".dart_tool/**",
      "android/.gradle/**",
      "android/app/build/**",
      "**/*.g.dart",
      "**/*.freezed.dart"
    ]
  }
}